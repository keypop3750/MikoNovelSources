# gitignore for MikoNovelSources

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# Android Studio / IntelliJ
.idea/
*.iml
*.ipr
*.iws
local.properties

# Build outputs
# *.apk  - Allowing APKs in /apk folder
!apk/*.apk
*.aab
*.ap_
*.dex

# Signing
*.keystore
*.jks
!debug.keystore

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Kotlin
*.kotlin_module

# Logs
*.log

# Test/probe scripts and build output artifacts
test_scripts/
build_output_*.txt
*_output.txt
novelpedia_comments_raw.json
novelfire_comment.min.js
logo_*.png
logo_*.ico
logo_*.svg
ic_launcher_*.png
